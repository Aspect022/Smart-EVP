# SmartEVP+ Mobile environment variables
# Copy this file to `.env` inside `Mobile/`
#
# Windows:
#   copy .env.example .env
#
# PowerShell:
#   Copy-Item .env.example .env
#
# Expo reads EXPO_PUBLIC_* variables and exposes them to the app.

# -----------------------------------------------------------------------------
# Optional but recommended:
# Explicit backend URL for Expo Go / phone testing.
# If left blank, the app tries to infer the laptop host automatically.
# -----------------------------------------------------------------------------
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.100:8080
