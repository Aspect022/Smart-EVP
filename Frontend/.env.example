# SmartEVP+ Frontend environment variables
# Copy this file to `.env.local` inside `Frontend/`
#
# Windows:
#   copy .env.example .env.local
#
# PowerShell:
#   Copy-Item .env.example .env.local

# -----------------------------------------------------------------------------
# Required: the backend URL the Next.js dashboard should talk to
# Use your Laptop 1 local IP for multi-device demo testing.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Optional / documented in project docs:
# Some docs mention Google Maps support for route/ETA enhancements.
# The current checked-in frontend code does not require this key yet,
# but keep it here as the expected variable if you add that integration.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# -----------------------------------------------------------------------------
# Required for Voice Input AI Brief (Ambulance Console):
# Get your key from https://aistudio.google.com/app/apikey
# This key is used client-side to call Gemini 2.0 Flash for medical brief generation.
# Without this, the voice input falls back to a placeholder brief.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GEMINI_API_KEY=
