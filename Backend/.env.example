# SmartEVP+ Backend environment variables
# Copy this file to `.env` inside `Backend/`
#
# Windows:
#   copy .env.example .env
#
# PowerShell:
#   Copy-Item .env.example .env
#
# Notes:
# - Only the backend needs real API secrets today.
# - You can run in demo/fallback mode with most of these left blank.

# -----------------------------------------------------------------------------
# Twilio: required only if you want real call intake and SMS dispatch
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567
DRIVER_PHONE=+919999999999

# -----------------------------------------------------------------------------
# Hugging Face: required only if you want live ASR API transcription
# If blank, the backend falls back to demo transcript behavior.
# -----------------------------------------------------------------------------
HF_API_KEY=

# -----------------------------------------------------------------------------
# Ollama / Gemini: optional AI brief providers
# Backend tries Ollama first, then Gemini, then hardcoded fallback brief.
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://10.1.16.183:11434
OLLAMA_MODEL=gpt-oss:120b-cloud
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Optional notes
# -----------------------------------------------------------------------------
# MQTT_BROKER and MQTT_PORT are currently hardcoded in config.py
# FLASK_HOST and FLASK_PORT are currently hardcoded in config.py
