# SmartEVP+ — Environment Variables
# Copy this to .env and fill in your values:
#   copy .env.example .env
#
# NEVER commit .env to git

# ── Twilio (Emergency Call Intake) ────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
DRIVER_PHONE=+91xxxxxxxxxx

# ── HuggingFace (for VibeVoice-ASR / Whisper API) ────────────
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Remote Ollama (Gemma runs on another machine) ─────────────
# Set this to the IP of the machine running Ollama + gemma2:2b
# Example: http://192.168.1.50:11434
# If empty, Gemma brief will use the hardcoded fallback brief.
OLLAMA_BASE_URL=http://192.168.x.x:11434
OLLAMA_MODEL=gemma2:2b
